{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ 파일 저장됨'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(node --version:*)",
      "Bash(git --version:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(ls:*)",
      "Bash(cat:*)"
    ],
    "deny": [],
    "ask": []
  }
}
